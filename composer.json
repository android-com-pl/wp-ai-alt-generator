{
  "name": "acpl/ai-alt-generator",
  "type": "wordpress-plugin",
  "autoload": {
    "psr-4": {
      "Acpl\\AltGenerator\\": "includes/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": "^8.1",
    "ext-mbstring": "*",
    "ext-intl": "*"
  },
  "require-dev": {
    "rector/rector": "^2.2",
    "carthage-software/mago": "^1.29"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "analyse:phpstan": "phpstan analyse",
    "clear-cache:phpstan": "phpstan clear-result-cache",
    "analyse:phpcs": "phpcs",
    "format": "phpcbf",
    "analyse:rector": "rector process --dry-run",
    "rector": "rector process"
  }
}
